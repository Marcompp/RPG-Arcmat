	"rickety_bridge": {
		"steps": [
			{"type": "text", "text": "The bridge ahead is ancient and rotting. The boards creak and sway with each gust of wind, gaps yawning between planks over a rushing river far below.\nIt feels like it could give way at any moment.", "clear": false},
			{"type": "choice", "header": "What do you do?",
				"choices": [
					{"choice": "Press on across the bridge", "key": "press_on"},
					{"choice": "Give up and go around",      "key": "give_up"}
				],
				"branches": {
					"give_up": [
						{"type": "exit_node", "exit": {"leads_to": "RIVER", "travel_text": "You decide not to risk it and pick your way along the riverbank, looking for a safer crossing."}}
					],
					"press_on": [
						{"type": "text", "text": "You step onto the bridge. Each board groans and flexes under your weight. The whole structure sways...[wait=0.2]\n...[wait=0.1]\n...[wait=0.1]", "clear": false, "no_wait": true},
						{"type": "random", "outcomes": [
							{
								"weight": 3, "stat_weights": {"dex": 1},
								"steps": [
									{"type": "text", "text": "You keep your weight balanced and move quickly from board to board. You're barely across when the final plank splinters into the water below!", "clear": false},
									{"type": "exit_node", "exit": {"leads_to": "ROAD", "travel_text": "You dash the last few steps off the bridge and continue down the road, heart still pounding."},"value":1.2}
								]
							},
							{
								"weight": 7,
								"steps": [
									{"type": "text", "text": "Halfway across, the bridge gives way with a sickening crack. The boards vanish beneath your feet and you plunge into the rushing water below!", "clear": false},
									{"type": "exit_node", "exit": {"leads_to": "RAPIDS", "travel_text": "The current drags you downstream through the rapids."},
										"enemies": ["Bitefish"], "encounter_rate": 1, "forbid_event": true, "value": 0
									}
								]
							}
						]}
					]
				}
			}
		]
	},
