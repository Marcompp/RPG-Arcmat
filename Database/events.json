					{"choice": "Slime", "key": "slime"}, 
					{"choice": "Bandit", "key": "bandit"},
					{"choice": "Skeleton", "key": "skeleton"},
					{"choice": "Slime Duo", "key": "slime2"},
					{"choice": "Bear", "key": "bear"},
					{"choice": "Werewolf", "key": "werewolf"},
					{"choice": "Back", "key": "back", "type": "back"}
				],
				"branches": {
					"slime": [
						{"type":"combat", "enemy": "Slime"}
					],
					"bandit": [
						{"type":"combat", "enemy": "Bandit"}
					],
					"skeleton": [
						{"type":"combat", "enemy": "Skeleton"}
					],
					"slime2": [
						{"type":"combat", "enemy": "Slime Duo"}
					],
					"bear": [
						{"type":"combat", "enemy": "Bear"}
					],
					"werewolf": [
						{"type":"combat", "enemy": "Werewolf"}
					],
					"back": [
					]
				}
