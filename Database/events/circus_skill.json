					},
					{
						"weight": 8,
						"stat_weights": {
							"dex": -0.2
						},
						"steps": [
							{
								"type": "sfx",
								"sound": "hit"
							},
							{
								"type": "random",
								"outcomes": [
									{
										"weight": 1,
										"steps": [
											{
												"type": "text",
												"text": "A clean hit, low on the board. Four points.",
												"clear": false,
												"no_continue": true
											}
										]
									},
									{
										"weight": 1,
										"steps": [
