												"text": "The dart sinks into the middle ring, unremarkable. Four.",
												"clear": false,
												"no_continue": true
											}
										]
									},
									{
										"weight": 1,
										"steps": [
											{
												"type": "text",
												"text": "\"Four,\" the clown says, already looking elsewhere. \"Fine. Adequate.\"",
												"clear": false,
												"no_continue": true
											}
										]
									},
									{
										"weight": 1,
										"steps": [
											{
												"type": "text",
												"text": "It thunks into the board with a satisfying little thud. Four points, nothing special.",
												"clear": false,
												"no_continue": true
											}
										]
									}
								]
							},
							{
								"type": "set_var",
								"vars": {
									"circus_skill_score": {
										"add": 4
									},
									"circus_skill_progress": {
										"add": 4
									}
								}
							}
						]
					},
					{
						"weight": 6,
						"stat_weights": {
							"dex": 0.2
						},
