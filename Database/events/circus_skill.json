						"stat_weights": {
							"dex": -1.2
						},
						"steps": [
							{
								"type": "sfx",
								"sound": "hit"
							},
							{
								"type": "random",
								"outcomes": [
									{
										"weight": 1,
										"steps": [
											{
												"type": "text",
												"text": "The dart sails wide and thunks into the wooden frame. Zero.",
												"clear": false,
												"no_continue": true
											}
										]
									},
									{
										"weight": 1,
										"steps": [
											{
												"type": "text",
												"text": "It clatters off the board entirely and rolls under the booth. Zero points.",
												"clear": false,
												"no_continue": true
											}
										]
									},
									{
										"weight": 1,
										"steps": [
