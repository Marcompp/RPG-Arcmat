{
    "circus_minigame_wit": {
		"repeatable": true,
		"steps": [
			{
				"type": "set_var",
				"vars": {
					"circus_wit_played": {
						"add": 1
					}
				}
			},
			{
				"type": "if",
				"condition": {
					"circus_wit_wins": {
						"min": 5
					}
				},
				"then": [
					{
						"type": "random",
						"outcomes": [
							{
								"weight": 1,
								"steps": [
									{
										"type": "text",
										"text": "\"Perfect score,\" the clown says flatly. \"That's what I need from you now. Five for five. Impossible questions, trick questions, no easy ones left. This is the real Trial of Wit.\"",
										"clear": true,
										"no_continue": true
									}
								]
							},
							{
								"weight": 1,
								"steps": [
									{
										"type": "text",
										"text": "\"You've beaten me enough times that I've stopped being nice about it.\" They fan out a final, ominous-looking deck. \"Five out of five. Good luck. You'll need it.\"",
										"clear": true,
										"no_continue": true
									}
								]
							}
						]
					},
					{
						"type": "quiz_game",
						"required_correct": 5,
						"difficulties": [
							"impossible",
							"trick"
						],
						"on_win": [
							{
								"type": "event",
								"event": "circus_wit_victory"
							}
						],
						"on_lose": [
							{
								"type": "event",
								"event": "circus_wit_defeat"
							}
						]
					}
				],
				"else": [
					{
						"type": "if",
						"condition": {
							"circus_wit_wins": 4
						},
						"then": [
							{
								"type": "random",
								"outcomes": [
									{
										"weight": 1,
										"steps": [
											{
												"type": "text",
												"text": "\"Four wins.\" The mask stops moving for a second. \"Fine. FINE. Have the really nasty questions. Some worldbuilding you couldn't possibly know yet. Some tricks. Good luck.\"",
												"clear": true,
												"no_continue": true
											}
										]
									},
									{
										"weight": 1,
										"steps": [
											{
												"type": "text",
												"text": "\"You're really doing this to me,\" they mutter, shuffling in a set of cards that seem to glow faintly with malice. \"Four of five. Go on, then.\"",
												"clear": true,
												"no_continue": true
											}
										]
									}
								]
							},
							{
								"type": "quiz_game",
								"required_correct": 4,
								"difficulties": [
									"hard",
									"impossible",
									"trick"
								],
								"on_win": [
									{
										"type": "event",
										"event": "circus_wit_victory"
									}
								],
								"on_lose": [
									{
										"type": "event",
										"event": "circus_wit_defeat"
									}
								]
							}
						],
