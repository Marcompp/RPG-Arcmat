	"fish_apple_carp": {
		"steps": [
			{
				"type": "text",
				"text": "A fat, lazy carp, belly round from eating fallen apples off the surface. It hardly fought at all.",
				"no_wait": true
			},
			{
				"type": "choice",
				"header": "What will you do?",
				"choices": [
					{
						"choice": "Eat it",
						"key": "eat"
					},
					{
						"choice": "Release it",
						"key": "release"
					}
				],
				"branches": {
					"eat": [
						{
							"type": "text",
							"text": "You eat it on the spot. Rich and sweet — whatever those apples did to it, you're not complaining.",
							"no_continue": true
						},
						{
							"type": "sfx",
							"sound": "heal"
						},
						{
							"type": "effect",
							"effect": {
								"type": "heal",
								"amount": 18
							}
						},
						{
							"type": "text",
							"text": "[instant]Healed [color=green]18[/color] HP![/instant]",
							"clear": false
						}
					],
					"release": [
						{
							"type": "text",
							"text": "You toss it back. It plops into the water and sinks without much ceremony."
						}
					]
				}
			}
		]
	},
	"fish_bigun": {
		"steps": [
			{
				"type": "text",
				"text": "Something hits the line. Not a nibble — a yank. The rod bends nearly double."
			},
			{
				"type": "text",
				"text": "You brace your feet against the bank and pull back. Whatever's down there is pulling harder."
			},
			{
				"type": "text",
				"text": "A shape rises beneath the surface — wide as a barrel, mud-dark. A head the size of a cooking pot breaks the water. It stares at you with one flat, indifferent eye.\n\nThe biggest catfish you've ever seen. By a considerable margin.",
				"clear": false,
				"no_wait": true
			},
			{
				"type": "choice",
				"header": "What do you do?",
				"choices": [
					{
						"choice": "Hold on and fight!",
						"key": "fight"
					},
					{
						"choice": "Cut the line and back away.",
						"key": "cut"
					}
				],
				"branches": {
					"fight": [
						{
							"type": "text",
							"text": "You dig your heels in. The catfish surges and splashes. You're not sure how long you can hold."
						},
						{
							"type": "combat",
							"enemy": "Big'Un"
						}
					],
					"cut": [
						{
							"type": "text",
							"text": "You pull your knife and sever the line. The rod springs back. The shape drops beneath the surface without a sound."
						},
						{
							"type": "text",
							"text": "The biggest fish you've ever seen, and you let it go. Probably for the best.",
							"clear": false
						}
					]
				}
			},
			{
				"type": "show_node"
			}
		]
	},
	"fish_bitefish": {
		"steps": [
			{
				"type": "text",
				"text": "The line goes taut hard and fast — whatever is on the other end doesn't want to be reeled in. It breaks the surface snapping."
			},
			{
				"type": "combat",
				"enemy": "Bitefish"
			}
		]
	},
	"fish_brown_apple": {
