					],
					"talk": [
						{
							"type": "set_var",
							"vars": {
								"cabin_talk_done": {
									"set": 1
								}
							}
						},
						{
							"type": "text",
							"text": "She stirs something on the fire without looking up.\n\n\"You're looking to cross the woods, aren't you.\"\n\nIt isn't a question.",
							"clear": true
						},
						{
							"type": "text",
							"text": "\"Beware, a Werewolf roams these woods.\"\n\n\"A man, once. A hunter.\" She taps the spoon against the pot. \"Beware that you do not become his prey, or follow in his fate.\"",
							"clear": false
						},
						{
							"type": "event",
							"event": "cabin_witch_choices"
						}
					],
					"leave": [
