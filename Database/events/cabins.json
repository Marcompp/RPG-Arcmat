			},
			{
				"type": "modify_node",
				"backdrop": "apple_cottage2.png"
			},
			{
				"type": "text",
				"text": "The door swings open before you can knock.\n\nWarm light spills out, carrying the smell of baked apple and dried herbs. \n\nAn old woman stands in the doorway, eyes bright under a wide-brimmed hat.",
				"clear": false
			},
			{
				"type": "set_var",
				"vars": {
					"cabin_rest_done": {
						"set": 0
					},
					"cabin_talk_done": {
						"set": 0
					}
				}
			},
			{
				"type": "text",
				"text": "\n\"I'm always happy to host a visitor.\" She steps aside and waves you in. \"Come in, come in. Rest up from your travels.\"",
				"clear": false,
				"no_wait": true
			},
			{
				"type": "event",
