					"shop": [
						{
							"type": "shop",
							"name": "Apple Witch's Stock",
							"shop": {
								"ShopType": "Item",
								"WelcomeText": "She gestures to a row of stoppered bottles on the shelf.\n\n\"Remedies brewed from the woods themselves — mixed them myself.\"\n\n\"Help yourself, for a price.\"",
								"OtherText": [
									"\"Take care of yourself out there.\"",
									"\"The woods don't forgive the unprepared.\""
								],
								"ambience": [
									"\"See anything you like?\"",
									"\"I've got plenty more in the cellar, don't worry.\""
								],
								"Stock": {
									"Potion": 30,
									"Ether": 40,
									"Medicine": 20,
									"Stimulant": 20
