							},
							{
								"type": "sfx",
								"sound": "chest_open"
							},
							{
								"type": "give_gold",
								"amount": 20
							},
							{
								"type": "text",
								"text": "You pry them out. [color=yellow]20G[/color].",
								"clear": false
							},
							{
								"type": "show_node"
							}
						]
					},
					{
						"weight": 2,
						"steps": [
							{
								"type": "text",
								"text": "A hand seizes your ankle from below.\n\nA Zombie — buried just under the rim, skin grey and dry.",
								"clear": false,
								"no_wait": true
							},
							{
								"type": "combat",
								"enemy": "Zombie",
								"on_victory": [
									{
										"type": "text",
										"text": "The grip goes slack. You pull away and steady yourself.",
										"clear": true
									},
									{
										"type": "show_node"
									}
								]
							}
						]
					},
					{
						"weight": 1,
						"stat_weights": {
							"lck": 1
						},
						"steps": [
							{
								"type": "text",
								"text": "Something glints far down in the crack. You fish it out with care.",
								"clear": false
							},
							{
								"type": "sfx",
								"sound": "chest_open"
							},
							{
								"type": "give_item",
								"item": "Potion"
							},
							{
								"type": "text",
								"text": "A [color=green]Potion[/color], still sealed.",
								"clear": false
							},
							{
								"type": "show_node"
							}
						]
					}
				]
			}
		]
	},
