{
	"skeleton_gambler": {
		"repeatable": false,
		"steps": [
			{
				"type": "text",
				"text": "You spot something up ahead:\"",
				"clear": false
			},
			{
				"type": "text",
				"text": "Among the headstones, a half-buried figure hunches over a flat-topped grave marker. Three dice on the stone in front of it. It doesn't have eyes anymore, but the empty sockets turn toward you when you approach.\n\n\"Sit,\" it says, in a voice like air through old stone. \"One game of Wandering Dice. That is all I ask.\"",
				"no_continue": true
			},
			{
				"type": "choice",
				"header": "Play or leave.",
				"choices": [
					{
						"choice": "50 gold — one game",
						"key": "play",
						"condition": {
							"gold": {
								"min": 50
							}
						},
						"disabled_text": "50 gold (can't afford)",
						"disabled_tooltip": "Requires at least 50G"
					},
					{
						"choice": "Walk away",
						"key": "leave"
					}
				],
				"branches": {
					"play": [
						{
							"type": "dice_game",
							"wager": 50,
							"gamblers": [
								"skeleton_gambler"
							],
							"community_dice": [
								"bone",
								"standard"
							],
							"on_win": [
								{
									"type": "text",
									"text": "Your hand takes it. He holds still for a moment, then counts out the coins and sets them in front of you.\n\n\"...Well played.\" He reaches behind the headstone and sets a die on the stone between you. Small, carved from bone, every face the same mark. \"Keep it. Something to remember the game by.\""
								},
								{
									"type": "give_item",
									"item": "skull"
								}
							],
							"on_tie": [
								{
									"type": "text",
									"text": "A dead match. He divides the pot exactly and sets your half in front of you without a word. Then he reaches behind the headstone and places a small die on the stone between you. Every face carved with the same sign.\n\n\"Even hands. Take this anyway.\""
								},
								{
									"type": "give_item",
									"item": "skull"
								}
							],
							"on_fold": [
								{
									"type": "text",
									"text": "You set your dice down. He pulls the pot to his side with careful hands.\n\n\"Wise, perhaps.\" He doesn't look up from the stone. \"Come back when you are ready.\""
								}
							],
							"on_lose": [
								{
									"type": "text",
									"text": "He sweeps the coins to his side slowly. Then reaches behind the headstone and sets a small bone die on the grave marker between you. Every face carved with the same sign.\n\n\"The game leaves something behind,\" he says. \"It always does.\""
								},
								{
									"type": "give_item",
									"item": "skull"
								}
							]
						},
						{
							"type": "show_node"
						}
					],
					"leave": [
						{
							"type": "text",
							"text": "You back away from the grave. The skeleton watches you go, then looks back down at its dice.\n\nIt doesn't call after you."
						},
						{
							"type": "show_node"
						}
					]
				}
			}
		]
	},
	"sundown_altar_event": {
		"repeatable": false,
		"steps": [
			{
				"type": "text",
				"text": "Up close, the altar is larger than it looked — a flat slab of dark stone, waist-high, stained with layered symbols that spiral toward the centre.\n\nThe stains are old and very dark. Something was done here regularly.",
				"clear": false,
				"no_wait": true
			},
			{
				"type": "choice",
				"header": "What do you do?",
				"choices": [
					{
						"choice": "Make a blood offering (10 HP)",
						"key": "offer"
					},
					{
						"choice": "Smash it",
						"key": "smash"
					},
					{
						"choice": "Leave it alone",
						"key": "leave"
					}
				],
				"branches": {
					"offer": [
						{
							"type": "effect",
							"effect": {
								"type": "damage",
								"amount": 10
							}
						},
						{
							"type": "text",
							"text": "You press your hand to the stone. The symbols flare cold — not warm — and something pulls at you, brief and deep.\n\nWhen it lets go, something rests on the altar that wasn't there before.",
							"clear": true
						},
						{
							"type": "sfx",
							"sound": "chest_open"
						},
						{
							"type": "give_item",
							"item": "Lifespark Crystal"
						},
						{
							"type": "text",
							"text": "You took [color=red]10 damage[/color].\nYou found a [color=yellow]Lifespark Crystal[/color].",
							"clear": false
						},
						{
							"type": "show_node"
						}
					],
					"smash": [
						{
							"type": "text",
							"text": "You bring your weight down on the altar. Stone chips and the spiral cracks through the centre.\n\nThe ground shifts.",
							"clear": true,
							"no_wait": true
						},
						{
							"type": "combat",
							"enemy": "Zombie",
							"on_victory": [
								{
									"type": "text",
									"text": "The noise disturbed something. The plateau grows quiet again.",
									"clear": true
								},
								{
									"type": "show_node"
								}
							]
						}
					],
					"leave": [
						{
							"type": "text",
							"text": "You leave the altar as you found it and move on.",
							"clear": false
						},
						{
							"type": "show_node"
						}
					]
				}
			}
		]
	},
	"sundown_cracked_earth": {
		"steps": [
			{
				"type": "text",
				"text": "A wide crevice splits the ground ahead — deeper than it looks, a faint light coming from the bottom.",
				"clear": false
			},
			{
				"type": "text",
				"text": "You crouch and look down...\n[wait=0.1]...[wait=0.1]",
				"clear": false
			},
			{
				"type": "random",
				"outcomes": [
					{
						"weight": 3,
						"steps": [
							{
								"type": "text",
								"text": "Nothing down there worth the trouble. Just loose stone and silence.",
								"clear": false
							},
							{
								"type": "show_node"
