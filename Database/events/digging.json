	"sundown_plateau_dig": {
		"steps": [
			{
				"type": "text",
				"text": "An old shovel stands upright in the cracked earth — broad blade, handle darkened with old sweat. It's been here long enough to be forgotten. The whole plateau is burial ground. Odds are something's under it."
			},
			{
				"type": "text",
				"text": "You get to work."
			},
			{
				"type": "sfx",
				"sound": "earth"
			},
			{
				"type": "random",
				"outcomes": [
					{
						"weight": 10,
						"steps": [
							{
								"type": "text",
								"text": "You dig until the blade hits something. You clear around it with your hands. A finger bone. Not a hand — just the one."
							},
							{
								"type": "event",
								"event": "sundown_plateau_dig_b"
							}
						]
					},
					{
						"weight": 8,
						"steps": [
							{
								"type": "text",
								"text": "You hit a coffin lid — intact, sealed, hinged. You consider it. You fill the hole back in."
							},
							{
								"type": "event",
								"event": "sundown_plateau_dig_b"
							}
						]
					},
					{
						"weight": 6,
						"steps": [
							{
								"type": "text",
								"text": "The blade bounces off hardpan — packed earth, dry as stone. Too dense to break without a longer tool. Nothing."
							},
							{
								"type": "event",
								"event": "sundown_plateau_dig_b"
							}
						]
					},
					{
						"weight": 5,
						"steps": [
							{
								"type": "text",
								"text": "The blade catches a buried stone wrong. The handle splinters clean through the grip and the head rings off into the dirt. That's the end of that."
							}
						]
					},
