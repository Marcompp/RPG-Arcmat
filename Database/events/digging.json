	"dig_abyssal_onyx": {
		"steps": [
			{
				"type": "text",
				"text": "Your blade splits a stone and the inside is different — black, smooth, no grain, no texture. Onyx, caught in the matrix. It breaks clean.\n\nYou found an [color=purple]Abyssal Onyx[/color]!"
			},
			{
