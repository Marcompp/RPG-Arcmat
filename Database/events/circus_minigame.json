	"circus_minigame_score": {
		"steps": [
			{
				"type": "text",
				"text": "[instant][table=7][cell][center][b]Game[/b][/center][/cell][cell][/cell][cell][center][b]Wins[/b][/center][/cell][cell][/cell][cell][center][b]Losses[/b][/center][/cell][cell][/cell][cell][center][b]Times Played[/b][/center][/cell][cell][center]Trial of Strength[/center][/cell][cell][/cell][cell][center][var=\"circus_strength_wins\"][/center][/cell][cell][/cell][cell][center][var=\"circus_strength_losses\"][/center][/cell][cell][/cell][cell][center][var=\"circus_strength_played\"][/center][/cell][cell][center]Trial of Skill[/center][/cell][cell][/cell][cell][center][var=\"circus_skill_wins\"][/center][/cell][cell][/cell][cell][center][var=\"circus_skill_losses\"][/center][/cell][cell][/cell][cell][center][var=\"circus_skill_played\"][/center][/cell][cell][center]Trial of Wit[/center][/cell][cell][/cell][cell][center][var=\"circus_wit_wins\"][/center][/cell][cell][/cell][cell][center][var=\"circus_wit_losses\"][/center][/cell][cell][/cell][cell][center][var=\"circus_wit_played\"][/center][/cell][cell][center]Trial of Luck[/center][/cell][cell][/cell][cell][center][var=\"circus_luck_wins\"][/center][/cell][cell][/cell][cell][center][var=\"circus_luck_losses\"][/center][/cell][cell][/cell][cell][center][var=\"circus_luck_played\"][/center][/cell][cell][center][b]Overall[/b][/center][/cell][cell][/cell][cell][center][b][var=\"circus_minigame_wins\"][/b][/center][/cell][cell][/cell][cell][center][b][var=\"circus_minigame_losses\"][/b][/center][/cell][cell][/cell][cell][center][b][var=\"circus_minigame_played\"][/b][/center][/cell][/table][/instant]",
