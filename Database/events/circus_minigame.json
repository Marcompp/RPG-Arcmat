	"circus_minigame_strength": {
		"repeatable": true,
		"steps": [
			{
				"type": "text",
				"text": "\"The Trial of Strength...\" The clown pauses. \"Ah — that ring's still being set up, actually. Very embarrassing.\" They slide your coins back across the counter. \"On the house. Come back another time.\"",
				"clear": true,
				"no_continue": true
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_fee": 10
				},
				"then": [
					{
						"type": "give_gold",
						"amount": 10
					}
				],
				"else": [
					{
						"type": "give_gold",
						"amount": 100
					}
				]
			},
			{
				"type": "event",
				"event": "circus_minigame_back"
			}
		]
	},
	"circus_minigame_victory": {
		"repeatable": true,
		"steps": [
			{
				"type": "sfx",
				"sound": "chest_open"
			},
			{
				"type": "give_gold",
				"amount": 100
			},
			{
				"type": "text",
				"text": "You got [color=yellow]100G[/color].",
				"clear": false,
				"no_continue": true
			},
			{
				"type": "set_var",
				"vars": {
					"circus_minigame_wins": {
						"add": 1
					}
				}
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_wins": 1
				},
				"then": [
					{
						"type": "text",
						"text": "From beneath the counter, they produce a small vial and slide it over. \"A little something for the road.\"",
						"clear": false,
						"no_continue": true
					},
					{
						"type": "give_item",
						"item": "Potion"
					}
				]
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_wins": 2
				},
				"then": [
					{
						"type": "text",
						"text": "\"Getting good at this.\" They toss you a vial that fizzes faintly on its own. \"Don't drink it out of curiosity.\"",
						"clear": false,
						"no_continue": true
					},
					{
						"type": "give_item",
						"item": "Stimulant"
					}
				]
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_wins": 3
				},
				"then": [
					{
						"type": "text",
						"text": "\"Three in a row.\" They produce a shimmering vial, careful not to touch it directly. \"Careful with that one.\"",
						"clear": false,
						"no_continue": true
					},
					{
						"type": "give_item",
						"item": "Ether"
					}
				]
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_wins": 4
				},
				"then": [
					{
						"type": "text",
						"text": "\"Four wins.\" The mask tilts, almost impressed. They press a peculiar periwinkle die into your palm — it hums faintly. \"That one likes you. Try not to lose it.\"",
						"clear": false,
						"no_continue": true
					},
					{
						"type": "give_item",
						"item": "circus"
					}
				]
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_wins": 5
				},
				"then": [
					{
						"type": "text",
						"text": "\"Five!\" They produce a scroll from absolutely nowhere and hand it over with a flourish. \"Learn a little something of mine.\"",
						"clear": false,
						"no_continue": true
					},
					{
						"type": "give_item",
						"item": "Party Trick Scroll"
					}
				]
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_wins": 6
				},
				"then": [
					{
						"type": "text",
						"text": "\"Six wins.\" For a moment, the mask stops moving entirely. Then they set a faintly glowing crystal on the counter. \"...That one's not really a prize. Take care of it.\"",
						"clear": false,
						"no_continue": true
					},
					{
						"type": "give_item",
						"item": "Lifespark Crystal"
					}
				]
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_wins": 7
				},
				"then": [
					{
						"type": "text",
						"text": "\"Seven.\" They go very quiet, then produce a long coiled whip from behind the booth — one that definitely wasn't there a moment ago. \"...The boss won't miss this. Probably.\"",
						"clear": false,
						"no_continue": true
					},
					{
						"type": "give_item",
						"item": "Ringmaster's Whip"
					}
				]
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_wins": 8
				},
				"then": [
					{
						"type": "text",
						"text": "\"Eight!\" Another scroll appears between their fingers, like it was always going to. \"One more trick, on the house.\"",
						"clear": false,
						"no_continue": true
					},
					{
						"type": "give_item",
						"item": "Juggle Throw Scroll"
					}
				]
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_wins": 9
				},
				"then": [
					{
						"type": "text",
						"text": "\"Nine wins.\" They produce a small dented bell and turn it over in their hands before setting it down. \"This one rings when it wants to. Not before.\"",
						"clear": false,
						"no_continue": true
					},
					{
						"type": "give_item",
						"item": "Chaos Bell"
					}
				]
			},
			{
				"type": "if",
				"condition": {
					"circus_minigame_wins": 10
				},
				"then": [
					{
						"type": "text",
						"text": "\"Ten.\" The clown goes utterly still. Then, slowly, they lift something from beneath the booth: a small, tarnished crown, sized for someone with a mask instead of a face. \"...Nobody's gotten this far before. Truly. Wear it well.\"",
						"clear": false,
						"no_continue": true
					},
					{
						"type": "give_item",
						"item": "Gamemaster's Crown"
					}
				]
			}
		]
	},
