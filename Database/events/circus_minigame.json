	"circus_minigame_games": {
		"repeatable": true,
		"steps": [
			{
				"type": "random",
				"outcomes": [
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "\"Wonderful!\" They clap once. \"What would you like to play?\"",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "\"That's the spirit!\" The clown leans over the counter, mask getting uncomfortably close. \"We're going to have so much fun together...\"",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "They spread their arms wide. \"Step right up! Which trial will you challenge, this time?\"",
								"clear": true,
								"no_continue": true
							}
						]
					}
				]
			},
			{
				"type": "choice",
				"header": "What would you like to play?",
				"choices": [
					{
						"choice": "Trial of Strength",
						"key": "strength"
					},
					{
						"choice": "Trial of Skill",
						"key": "skill"
					},
					{
						"choice": "Trial of Wit",
						"key": "wit"
					},
					{
						"choice": "Trial of Luck",
						"key": "luck"
					},
					{
						"choice": "Back",
						"key": "back",
						"type": "back"
					}
				],
				"branches": {
					"strength": [
						{
							"type": "set_var",
