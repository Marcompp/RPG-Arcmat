								"text": "The clown taps the counter twice. \"Is that all you needed?\"",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "\"Anything else?\"",
								"clear": true,
								"no_continue": true
