									"set": 1
								}
							}
						},
						{
							"type": "event",
							"event": "circus_minigame_pay"
						}
					],
					"skill": [
						{
							"type": "set_var",
							"vars": {
								"circus_which_minigame": {
									"set": 2
								}
							}
						},
						{
							"type": "event",
							"event": "circus_minigame_pay"
						}
					],
					"wit": [
						{
							"type": "random",
							"outcomes": [
								{
									"weight": 1,
									"steps": [
										{
											"type": "text",
											"text": "\"The Trial of Wit.\" The Gamer Clown spins around and faces you. \"Good choice! I've been waiting for someone to pick Wit.\"",
											"clear": true,
											"no_continue": true
										}
									]
								},
								{
									"weight": 1,
									"steps": [
										{
											"type": "text",
											"text": "They stop. Tilt their head sideways. \"Wit,\" they repeat, slowly. \"Interesting choice.\" One side of the mask grins wider, the other frowns harder. Or maybe it always looked like that.",
											"clear": true,
											"no_continue": true
										}
									]
								},
								{
									"weight": 1,
									"steps": [
										{
											"type": "text",
											"text": "\"Ah, the brainy type.\" They tap the side of their mask. \"Most go for one of the others first. Not you. I respect that. It won't help you, but I respect it.\"",
											"clear": true,
											"no_continue": true
										}
									]
								}
							]
						},
						{
							"type": "set_var",
							"vars": {
								"circus_which_minigame": {
									"set": 3
								}
							}
						},
						{
							"type": "event",
							"event": "circus_minigame_pay"
						}
					],
					"luck": [
						{
							"type": "set_var",
							"vars": {
								"circus_which_minigame": {
									"set": 4
								}
							}
						},
						{
							"type": "event",
							"event": "circus_minigame_pay"
						}
					],
					"back": [
						{
							"type": "random",
							"outcomes": [
								{
									"weight": 1,
									"steps": [
										{
											"type": "text",
											"text": "\"Lame.\" They turn away. \"You're lame. Absolutely lame. Do something.\"",
											"clear": true,
											"no_continue": true
										}
									]
								},
								{
									"weight": 1,
									"steps": [
										{
											"type": "text",
											"text": "They stare at you for a long moment.\n\n\"...You're funny.\" The mask tilts. \"What do you want to do now?\"",
											"clear": true,
											"no_continue": true
										}
									]
								},
								{
									"weight": 1,
									"steps": [
										{
											"type": "text",
											"text": "\"Changed your mind?\" They shrug with their whole body. \"Fine. Back to the start, back to the start. We've got all the time in the world.\"",
											"clear": true,
											"no_continue": true
										}
									]
								}
							]
						},
						{
							"type": "event",
							"event": "circus_minigame_choices"
						}
					]
				}
			}
		]
	},
