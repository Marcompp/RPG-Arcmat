	"circus_stage": {
		"repeatable": true,
		"steps": [
			{
				"type": "text",
				"text": "A spotlight snaps on above the main stage. The ringmaster's voice echoes from nowhere: \"Ladies and gentlemen — it is time for the dance to begin!\"",
				"no_wait": true
			},
			{
				"type": "if",
				"condition": {
					"stage_fights": {
						"min": 1
					}
				},
				"then": [
					{
						"type": "text",
						"text": "Two Harlequins vault onto the stage from either side, knives already drawn. The crowd holds its breath.",
						"clear": false,
						"no_wait": true
					}
				],
				"else": [
					{
						"type": "text",
						"text": "A Harlequin cartwheels onto the stage, knife in hand, porcelain mask obscuring their face.",
						"clear": false,
						"no_wait": true
					}
				]
			},
			{
				"type": "text",
				"text": "A spotlight snaps to you, and the ringmaster's voice speaks: \"A challenger approaches! Will they step up and join the dance?\"",
				"clear": false,
				"no_wait": true
			},
			{
				"type": "choice",
				"header": "What do you do?",
				"choices": [
					{
						"choice": "Join the dance",
						"key": "fight"
					},
					{
						"choice": "Leave",
						"key": "leave",
						"type": "back"
					}
				],
				"branches": {
					"fight": [
						{
							"type": "if",
							"condition": {
								"stage_fights": {
									"min": 1
								}
							},
							"then": [
								{
									"type": "combat",
									"enemy": "Harlequin Duo",
									"on_victory": [
										{
											"type": "event",
											"event": "_circus_stage_victory"
										}
									],
									"on_defeat": [
										{
											"type": "event",
											"event": "_circus_stage_defeat"
										}
									]
								}
							],
							"else": [
								{
									"type": "combat",
									"enemy": "Harlequin",
									"on_victory": [
										{
											"type": "event",
											"event": "_circus_stage_victory"
										}
									],
									"on_defeat": [
										{
											"type": "event",
											"event": "_circus_stage_defeat"
										}
									]
								}
							]
						}
					],
					"leave": []
				}
			}
		]
	},
