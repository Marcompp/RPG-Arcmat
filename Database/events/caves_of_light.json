	"wounded_spirit": {
		"repeatable": false,
		"steps": [
			{
				"type": "text",
				"text": "Something drifts near the surface of the spring — pale and flickering, circling in the crystal light. A Restless Spirit. But it isn't moving toward you. It moves as if confused, or searching.",
				"clear": false,
				"no_wait": true
			},
			{
				"type": "choice",
				"header": "What do you do?",
				"choices": [
					{
						"choice": "Speak to it",
						"key": "speak"
					},
					{
						"choice": "Strike first",
						"key": "strike"
					},
					{
						"choice": "Leave it alone",
						"key": "leave"
					}
				],
				"branches": {
					"speak": [
						{
							"type": "text",
							"text": "You speak quietly. It stops circling.\n\nFor a moment, nothing — then something passes between you. Not words. An impression of torchlight. Robed figures. A blade.\n\nThen it dissolves, scattering across the surface of the spring and vanishing into the stone.",
							"clear": true
						},
						{
							"type": "sfx",
							"sound": "heal"
						},
						{
							"type": "effect",
							"effect": {
								"type": "restore_mp",
								"amount": 15
							}
						},
						{
							"type": "text",
							"text": "Something lingers in the air — a faint warmth.\n[color=teal]MP +15[/color]",
							"clear": false
						},
						{
							"type": "show_node"
						}
					],
					"strike": [
						{
							"type": "text",
							"text": "You don't wait to find out what it wants.",
							"clear": false,
							"no_wait": true
						},
						{
							"type": "combat",
							"enemy": "Restless Spirit",
							"on_victory": [
								{
									"type": "text",
									"text": "The spirit unravels. The spring is still.",
									"clear": true
								},
								{
									"type": "show_node"
								}
							]
						}
					],
					"leave": [
						{
							"type": "text",
							"text": "You give it a wide berth and move on. It doesn't follow.",
							"clear": false
						},
						{
							"type": "show_node"
						}
					]
				}
			}
		]
	}
