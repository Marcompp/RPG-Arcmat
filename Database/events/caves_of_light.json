										},
										{
											"type": "show_node"
										}
									]
								},
								{
									"weight": 5,
									"steps": [
										{
											"type": "text",
											"text": "The stone floor gives nothing away. Every passage looks identical in both directions.",
											"clear": false
										},
										{
											"type": "exit_node",
											"exit": {
												"leads_to": "TUNNEL",
												"travel_text": "You pick a direction and commit to it, hoping to find something familiar.",
												"value": 0
											}
										}
									]
								}
							]
						}
					],
					"move": [
						{
							"type": "text",
							"text": "You pick a direction and walk.",
							"clear": false,
							"no_wait": true
						},
