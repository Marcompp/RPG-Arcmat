										{
											"type": "sfx",
											"sound": "hit"
										},
										{
											"type": "effect",
											"effect": {
												"type": "damage",
												"amount": 20
											}
										},
										{
											"type": "show_node"
										}
									]
								}
							]
						}
					]
				}
			}
		]
	},
	"cave_lost": {
		"repeatable": false,
		"steps": [
			{
				"type": "text",
				"text": "The tunnels blur together. The same crystals. The same shadows. The same glow from every direction at once.\n\nYou've lost track of where you came from.",
				"clear": false,
				"no_wait": true
			},
			{
				"type": "choice",
				"header": "What do you do?",
				"choices": [
					{
						"choice": "Follow the light",
						"key": "light"
					},
					{
						"choice": "Retrace your steps",
						"key": "retrace"
					},
					{
						"choice": "Keep moving",
						"key": "move"
					}
				],
				"branches": {
					"light": [
						{
							"type": "random",
							"outcomes": [
								{
									"weight": 5,
									"stat_weights": {
										"lck": 1
									},
									"steps": [
										{
											"type": "text",
											"text": "The crystals pulse slightly brighter in one direction. Maybe you imagined it. Either way, you follow — and the passage opens ahead.",
											"clear": false
										},
										{
											"type": "show_node"
										}
									]
								},
								{
									"weight": 5,
									"steps": [
										{
											"type": "text",
											"text": "The crystals lead you in a wide circle. You emerge from the wrong direction, wasting precious time.",
											"clear": false
										},
										{
											"type": "exit_node",
											"exit": {
												"leads_to": "TUNNEL",
												"travel_text": "You retrace your steps, unsure how much ground you've lost.",
												"value": -2
											}
										}
									]
								}
							]
						}
					],
					"retrace": [
						{
							"type": "random",
							"outcomes": [
								{
									"weight": 5,
									"stat_weights": {
										"dex": 1
									},
									"steps": [
										{
											"type": "text",
											"text": "You note the scuffs in the dust, the faint impressions in the grit. Slowly, the path resolves.",
											"clear": false
										},
										{
											"type": "show_node"
										}
									]
								},
								{
									"weight": 5,
									"steps": [
										{
											"type": "text",
											"text": "The stone floor gives nothing away. Every passage looks identical in both directions.",
											"clear": false
										},
										{
											"type": "exit_node",
											"exit": {
												"leads_to": "TUNNEL",
												"travel_text": "You pick a direction and commit to it, hoping to find something familiar.",
												"value": 0
											}
										}
									]
								}
							]
						}
					],
					"move": [
						{
							"type": "text",
							"text": "You pick a direction and walk.",
							"clear": false,
							"no_wait": true
						},
						{
							"type": "random",
							"outcomes": [
								{
									"weight": 3,
									"stat_weights": {
										"lck": 1
									},
									"steps": [
										{
											"type": "text",
											"text": "After a long while, the passage opens somewhere new. Not ideal, but somewhere.",
											"clear": false
										},
										{
											"type": "show_node"
										}
									]
								},
								{
									"weight": 7,
									"steps": [
										{
											"type": "text",
											"text": "You walk for what feels like an hour and find nothing useful. You double back, worn out.",
											"clear": false,
											"no_continue": true
										},
										{
											"type": "sfx",
											"sound": "poison"
										},
										{
											"type": "effect",
											"effect": {
												"type": "damage",
												"amount": 3
											}
										},
										{
											"type": "text",
											"text": "[instant]Lost [color=red]3[/color] HP from exhaustion.[/instant]",
											"clear": false
										},
										{
											"type": "show_node"
										}
									]
								}
							]
						}
					]
				}
			}
		]
	},
