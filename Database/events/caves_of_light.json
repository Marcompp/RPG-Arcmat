	"cave_in": {
		"steps": [
			{
				"type": "text",
				"text": "The mountain shudders. A deep crack splits the ceiling above and a cascade of rock and dust comes down — you have about two seconds.",
				"no_wait": true
			},
			{
				"type": "choice",
				"header": "What do you do?",
				"choices": [
					{
						"choice": "Run for it",
						"key": "run"
					},
					{
						"choice": "Brace and cover your head",
						"key": "brace"
					}
				],
				"branches": {
					"run": [
						{
							"type": "random",
							"outcomes": [
								{
									"weight": 3,
									"stat_weights": {
										"agi": 1
									},
									"steps": [
										{
											"type": "text",
											"text": "You sprint and clear the worst of it. Dust and small debris rain down on your back, but nothing catastrophic. You keep moving."
										},
										{
											"type": "show_node"
										}
									]
								},
								{
									"weight": 7,
									"steps": [
										{
											"type": "text",
											"text": "You're almost clear when a chunk of basalt clips your shoulder. The impact is sharp and immediate."
										},
										{
											"type": "sfx",
											"sound": "hit"
										},
										{
											"type": "effect",
											"effect": {
												"type": "damage",
												"amount": 15
											}
										},
										{
											"type": "show_node"
										}
									]
								}
							]
						}
					],
					"brace": [
						{
							"type": "random",
							"outcomes": [
								{
									"weight": 70,
									"steps": [
										{
											"type": "text",
											"text": "You press against the nearest wall, arms over your head. The debris rattles and bounces around you. When the dust settles, you're intact."
										},
										{
											"type": "show_node"
										}
									]
								},
								{
									"weight": 30,
									"steps": [
										{
