										"condition": {
											"circus_luck_wins": {
												"min": 1
											}
										},
										"then": [
											{
												"type": "text",
												"text": "\"You might've beaten me once, but that doesn't mean it'll happen again, I'm afraid.\"\n\nThe Gamer Clown steps up onto the booth counter.\n\n\"Ready for round two?\" They spread their arms wide — and then something happens.\n\nThey split.\n\nTwo figures drop to either side of the counter: one with a mask fixed in a permanent grin, one with a mask pulled into a long, deep frown.",
												"clear": true,
												"no_continue": true
											},
											{
												"type": "text",
												"text": "The Smiley Clown claps their hands. The Frowny Clown sighs.\n\n\"Better get your dice out,\" they say, not quite in unison.",
												"clear": false,
												"no_continue": false
											},
											{
												"type": "dice_game",
												"wager": 0,
