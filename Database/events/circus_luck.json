								"condition": {
									"circus_luck_wins": 2
								},
								"then": [
									{
										"type": "text",
										"text": "The Gamer Clown leans on the counter and looks at you for a long moment.\n\n\"You're going to regret trying for a third win.\" They say it almost fondly.\n\nThen they split.\n\nThree figures, this time: the grinning one, the frowning one, and a third — flat-faced, blank-masked, completely expressionless.",
										"clear": true,
										"no_continue": true
									},
									{
										"type": "text",
										"text": "The Serious Clown stares at you.\n\nThe other two make noise. You focus on the Serious Clown.",
										"clear": false,
										"no_continue": false
									},
									{
										"type": "dice_game",
										"wager": 0,
										"gamblers": [
