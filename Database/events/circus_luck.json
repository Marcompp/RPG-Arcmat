	"circus_luck_defeat": {
		"repeatable": true,
		"steps": [
			{
				"type": "random",
				"outcomes": [
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "They sweep the coins off the counter.\n\n\"Too bad.\" The mask grins. \"Looks like you just weren't lucky enough.\"",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "\"Ohhh, so close.\" They watch the result, unmoved. \"The dice decide, not me. Blame the dice.\"",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "They lean over the counter. \"Bad luck. Pure bad luck.\" A beat. \"Come back and try again.\" They do not sound sincere, and don't bother pretending otherwise.",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "\"The crowd gives you a solid...\" They tilt a hand side to side. \"Meeeh. Better luck next time. Maybe.\"",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "They pocket the coins without ceremony. \"Play more. Get Better. Come back. Lose again. That's the whole pitch, really.\"",
								"clear": true,
								"no_continue": true
							}
						]
					}
				]
			},
			{
				"type": "set_var",
				"vars": {
					"circus_minigame_losses": {
						"add": 1
					},
					"circus_luck_losses": {
						"add": 1
					}
				}
			},
			{
				"type": "event",
				"event": "circus_luck_replay"
			}
		]
	},
	"circus_luck_replay": {
		"repeatable": true,
		"steps": [
			{
				"type": "random",
				"outcomes": [
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "They slap the counter. \"Rematch! One hundred gold, right now, I won't even make you wait!\"",
								"clear": false,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "\"Another game?\" They're already rearranging the dice. \"Hundred gold. Quick as you like.\"",
								"clear": false,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "They stare at you. \"...Go again? Hundred gold. Yes or no.\"",
								"clear": false,
								"no_continue": true
							}
						]
					}
				]
			},
			{
				"type": "event",
				"event": "circus_minigame_replay"
			}
		]
	},
	"circus_luck_victory": {
		"repeatable": true,
		"steps": [
			{
				"type": "random",
				"outcomes": [
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "\"Well.\" They stare at the dice. \"Well. Look at that.\" They sweep the coins across the counter toward you. \"I don't do that often. Enjoy it while it lasts.\"",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "They say nothing for a long moment. Then clap. Once. \"Okay. Fine. You win. Take your coins.\"",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "\"Extraordinary!\" They bounce on the spot in an almost forced movement. \"Good job! Good job!\"",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "They pull the coins back toward you with two fingers, slowly. \"...I'm going to need a minute.\"",
								"clear": true,
								"no_continue": true
							}
						]
					},
					{
						"weight": 1,
						"steps": [
							{
								"type": "text",
								"text": "\"Fair and square!\" They spread their hands. \"Can't argue with it. Take your reward — this time.\"",
								"clear": true,
								"no_continue": true
							}
						]
					}
				]
			},
			{
				"type": "set_var",
				"vars": {
					"circus_luck_wins": {
						"add": 1
					}
				}
			},
			{
				"type": "event",
				"event": "circus_minigame_victory"
			},
			{
				"type": "event",
				"event": "circus_luck_replay"
			}
		]
	}
