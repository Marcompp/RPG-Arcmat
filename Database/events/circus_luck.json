								"steps": [
									{
										"type": "text",
										"text": "They rub their hands together. \"Back for more? Back for more. You just keep coming back.\"",
										"clear": true,
										"no_continue": true
									}
								]
							},
							{
								"weight": 1,
								"steps": [
									{
										"type": "text",
										"text": "The mask stares at you. \"I genuinely cannot tell if you're very good or very lucky. Either way.\" They shrug. \"Let's find out.\"",
										"clear": true,
										"no_continue": true
									}
								]
							},
							{
								"weight": 1,
								"steps": [
									{
										"type": "text",
										"text": "\"You.\" They point. \"You are becoming a problem. A wonderful, profitable — for me — problem.\"",
										"clear": true,
										"no_continue": true
									}
								]
							},
							{
								"weight": 1,
								"steps": [
									{
										"type": "text",
										"text": "They count on their fingers, lips moving. Then give up. \"You've come back more times than I can count. That's... well, it probably says more about me than you, no?\"",
										"clear": true,
										"no_continue": true
									}
								]
							},
							{
								"weight": 1,
								"steps": [
									{
										"type": "text",
										"text": "\"I had to send for reinforcements,\" they say, entirely sincere. \"You'll see.\"",
										"clear": true,
										"no_continue": true
									}
								]
