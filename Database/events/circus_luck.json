														"event": "circus_luck_victory"
													}
												],
												"on_tie": [
													{
														"type": "event",
														"event": "circus_luck_victory"
													}
												],
												"on_fold": [
													{
														"type": "event",
														"event": "circus_luck_defeat"
													}
												],
												"on_lose": [
													{
														"type": "event",
														"event": "circus_luck_defeat"
													}
												]
											}
										],
										"else": [
											{
												"type": "text",
												"text": "\"For the Trial of Luck,\" the Gamer Clown announces, climbing atop the booth, \"you shall be facing *ME* in the most brutal, the most STRATEGIC, the most cunningly devised game ever conceived by any mind both fevered and brilliant...\"",
												"clear": true,
												"no_continue": true
											},
											{
												"type": "text",
												"text": "\"[wait=0.1]...[wait=0.1]WANDERER'S DICE!\"\n\nThey produce a set of dice from somewhere and set them on the counter with a flourish.",
												"clear": false,
												"no_continue": true
											},
											{
												"type": "text",
												"text": "They gesture at you. \"Better get your dice out!\"",
												"clear": false,
												"no_continue": false
											},
											{
