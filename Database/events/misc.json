{
	"altar_offering": {
		"repeatable": false,
		"steps": [
			{
				"type": "text",
				"text": "You approach the altar. It radiates a concentrated warmth — not heat exactly, but presence. Faint markings pulse in slow rhythm across the stone. A shallow basin at its centre is worn smooth by countless offerings.",
				"clear": false,
				"no_wait": true
			},
			{
				"type": "choice",
				"header": "What do you do?",
				"choices": [
					{
						"choice": "Make an offering (30G)",
						"key": "offer",
						"condition": {
							"gold": {
								"min": 30
							}
						},
						"disabled_tooltip": "Not enough gold (need 30G)"
					},
					{
						"choice": "Leave",
						"key": "leave"
					}
				],
				"branches": {
					"offer": [
						{
							"type": "give_gold",
							"amount": -30
						},
						{
							"type": "text",
							"text": "You place 30G in the basin. The coins catch the crystal light — then the glow intensifies, warm and steady, filling the chamber.\n\nWhen it fades, something rests where your offering was.",
							"clear": true,
							"no_continue": true
						},
						{
							"type": "sfx",
							"sound": "chest_open"
						},
						{
							"type": "give_item",
							"item": "Book of Heal"
						},
						{
							"type": "text",
							"text": "You found the [color=green]Book of Heal[/color].",
							"clear": false
						},
						{
							"type": "show_node"
						}
					],
					"leave": [
						{
							"type": "text",
							"text": "You leave the altar undisturbed and press on.",
							"clear": false
						},
						{
							"type": "show_node"
						}
					]
				}
			}
		]
	},
	"bandit_ambush": {
		"repeatable": false,
		"steps": [
			{
				"type": "text",
				"text": "You hear rustling in the bushes...",
				"clear": false
			},
			{
				"type": "text",
				"text": "Too late — you walked straight into an ambush!\n\nTwo bandits leap out and block the road!\n\n\"You're in our turf now, pal!\"\n\n\"You'll be much easier to rob when you're dead!\"",
				"no_wait": true
			},
			{
				"type": "choice",
				"header": "What do you do?",
				"choices": [
					{
						"choice": "Fight",
						"key": "fight"
					},
					{
						"choice": "Pay them off (100G)",
						"key": "pay",
						"condition": {
							"gold": {
								"min": 100
							}
						},
						"disabled_tooltip": "Not enough gold (need 100G)"
					},
					{
						"choice": "Turn them against each other",
						"key": "trick"
					}
				],
				"branches": {
					"fight": [
						{
							"type": "combat",
							"enemy": "Bandit Brothers",
							"on_victory": [
								{
									"type": "show_node"
								}
							]
						}
					],
					"pay": [
						{
							"type": "give_gold",
							"amount": -100
						},
						{
							"type": "text",
							"text": "You reach into your purse and shove a fistful of coins at the nearest bandit — not counting, not stopping. You're already moving.\n\nBehind you, you hear them counting. Then arguing about the count.\n\nYou don't look back.",
							"clear": true
						},
						{
							"type": "show_node"
						}
					],
					"trick": [
						{
							"type": "random",
							"outcomes": [
								{
									"weight": 3,
									"stat_weights": {
										"lck": 1
									},
									"steps": [
										{
											"type": "text",
											"text": "You glance at the second bandit. 'You know what he said about you back there?'\n\n'What?' The first one turns. 'I never said—'\n'I'm sure you didn't.'\n'You did say something—' 'I never—'\n\nYou're around them and gone before they've finished.",
											"clear": true
										},
										{
											"type": "show_node"
										}
									]
								},
								{
									"weight": 7,
									"steps": [
										{
											"type": "text",
											"text": "'Even we've heard that one.'\n\nThey both take a step forward.",
											"clear": false,
											"no_wait": true
										},
										{
											"type": "combat",
											"enemy": "Bandit Brothers",
											"on_victory": [
												{
													"type": "show_node"
												}
											]
										}
									]
								}
							]
						}
					]
				}
			}
		]
	},
